{
    // See https://go.microsoft.com/fwlink/?LinkId=733558
    // for the documentation about the tasks.json format
    "version": "2.0.0",
    "command": "tsc",
    "args": [
        "-w",
        "-p",
        "."
    ],
    "isBackground": true,
    "problemMatcher": "$tsc-watch",
    "tasks": [
        {
            "label": "OpenCode",
            "type": "shell",
            "command": "opencode web",
            "isBackground": true,
            "problemMatcher": [],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
        },
        {
            "label": "Build",
            "type": "shell",
            "command": "make build",
            "options": {
                "cwd": "${workspaceFolder}/golang/"
            },
            "isBackground": true,
            "problemMatcher": [],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
    ]
}
