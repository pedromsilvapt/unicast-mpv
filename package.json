{
  "name": "unicast-mpv",
  "version": "0.1.15",
  "description": "A simple module that exposes MPV to be controlled through a RPC WebSockets API, that can be used with the unicast server",
  "main": "lib/index.js",
  "bin": "lib/cli.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "pkg": {
    "targets": [
      "node12-linux-x64",
      "node12-macos-x64",
      "node12-win-x64"
    ],
    "outputPath": "./build/",
    "scripts": "lib/**/*.js",
    "assets": [
      "src/**/*.js",
      "config/**/*.yaml"
    ]
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@pedromsilva/data-future": "^1.1.2",
    "case": "^1.6.1",
    "chalk": "^2.4.2",
    "clui-logger": "^0.2.1",
    "data-stopwatch": "^0.1.0",
    "extend": "^3.0.2",
    "js-yaml": "^3.13.1",
    "mz": "^2.7.0",
    "node-mpv": "github:pedromsilvapt/Node-MPV#83e9132acedbf7189ef349f46abd7a9e849713b3",
    "object-path": "^0.11.4",
    "rpc-websockets": "^4.3.5"
  },
  "devDependencies": {
    "@types/mz": "0.0.32",
    "@types/node": "^11.13.4",
    "typescript": "^4.9.5"
  }
}
